@HostAddress = http://localhost:5062/api/tariff-tables

### ==========================================
### 1. REGRAS GERAIS (ESTADO -> ESTADO)
### Essas regras têm prefixos curtos (1 dígito) e servem como "Fallback".
### SP (0) para RJ (2)
### ==========================================

POST {{HostAddress}}
Accept: */*
Content-Type: application/json

{
  "description": "Estado SP para Estado RJ - Leve",
  "originPrefix": "0",
  "destinationPrefix": "2",
  "minWeightKg": 0.3,
  "maxWeightKg": 5,
  "baseValueAmount": 35.00,
  "currency": "BRL"
}

###

POST {{HostAddress}}
Accept: */*
Content-Type: application/json

{
  "description": "Estado SP para Estado RJ - Pesado",
  "originPrefix": "0",
  "destinationPrefix": "2",
  "minWeightKg": 5.01,
  "maxWeightKg": 30,
  "baseValueAmount": 80.00,
  "currency": "BRL"
}

###

POST {{HostAddress}}
Accept: */*
Content-Type: application/json

{
  "description": "Estado SP para Estado MG - Padrão",
